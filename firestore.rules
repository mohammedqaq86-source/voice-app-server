rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isRoomOwner(roomId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/rooms/$(roomId)).data.ownerId == request.auth.uid;
    }

    // Fields that only the room owner may set on a member doc
    function touchesSensitiveFields() {
      return request.resource.data.diff(resource.data)
        .affectedKeys()
        .hasAny(['isLeader', 'hasMicPermission']);
    }

    // ─── Users ───────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);

      // socialLinks: owner of the doc OR the linked user can write.
      match /socialLinks/{linkId} {
        allow read:   if isOwner(userId);
        allow write:  if isOwner(userId) || isOwner(linkId);
        allow delete: if isOwner(userId) || isOwner(linkId);
      }

      // Invites stored under the user
      match /invites/{roomId} {
        allow read:   if isOwner(userId);
        allow create: if isSignedIn();
        allow update: if isSignedIn();
        allow delete: if isOwner(userId) || isRoomOwner(roomId);
      }

      // Notifications: anyone signed in can push one to you, only you can read/manage
      match /notifications/{notifId} {
        allow read:   if isOwner(userId);
        allow create: if isSignedIn();
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }
    }

    // ─── Rooms ───────────────────────────────────────────────────────────────
    match /rooms/{roomId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      // Room owner can update anything; others can only touch usersCount/speakersCount
      allow update: if isSignedIn() && (
        isRoomOwner(roomId) ||
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['usersCount', 'speakersCount'])
      );
      allow delete: if isRoomOwner(roomId);

      // Members: room owner has full control.
      // Members may update their own doc but CANNOT elevate their own privileges.
      match /members/{memberId} {
        allow read:   if isSignedIn();
        allow create: if isOwner(memberId) || isRoomOwner(roomId);
        allow update: if isRoomOwner(roomId)
                      || (isOwner(memberId) && !touchesSensitiveFields());
        allow delete: if isOwner(memberId) || isRoomOwner(roomId);
      }

      // Kicked users: only the room owner can manage this list
      match /kickedUsers/{userId} {
        allow read:   if isSignedIn();
        allow write:  if isRoomOwner(roomId);
        allow delete: if isRoomOwner(roomId);
      }

      // Room-level invites: owner sends/revokes; invited user can read/delete their own
      match /invites/{userId} {
        allow read:   if isOwner(userId) || isRoomOwner(roomId);
        allow create: if isRoomOwner(roomId);
        allow update: if isRoomOwner(roomId);
        allow delete: if isOwner(userId) || isRoomOwner(roomId);
      }

      // Chat messages: any signed-in user can read and write (system + regular)
      match /messages/{messageId} {
        allow read:   if isSignedIn();
        allow create: if isSignedIn() && (
          request.resource.data.type == 'system' ||
          request.resource.data.userId == request.auth.uid
        );
        allow update: if isRoomOwner(roomId);
        allow delete: if isRoomOwner(roomId);
      }
    }
  }
}
