rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isRoomOwner(roomId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/rooms/$(roomId)).data.ownerId == request.auth.uid;
    }

    // Member with isLeader=true can also perform admin actions as a fallback.
    function isRoomLeader(roomId) {
      let memberRef = /databases/$(database)/documents/rooms/$(roomId)/members/$(request.auth.uid);
      return isSignedIn() &&
        exists(memberRef) &&
        get(memberRef).data.isLeader == true;
    }

    // Returns true when the request changes the isLeader field.
    // Leaders are allowed to update mic/status but only the owner can change isLeader.
    function touchesLeaderField() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny(['isLeader']);
    }

    // Fields that only the room owner may set on a member doc.
    // Allows members to revoke their own mic (set to false) but NOT elevate (set to true).
    function touchesSensitiveFields() {
      let affected = request.resource.data.diff(resource.data).affectedKeys();
      // isLeader: never changeable by the member themselves
      if (affected.hasAny(['isLeader'])) { return true; }
      // hasMicPermission: sensitive only when being ELEVATED to true
      if (affected.hasAny(['hasMicPermission']) && request.resource.data.hasMicPermission == true) {
        return true;
      }
      return false;
    }

    // ─── Users ───────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);

      // socialLinks: owner of the doc OR the linked user can write.
      match /socialLinks/{linkId} {
        allow read:   if isOwner(userId);
        allow write:  if isOwner(userId) || isOwner(linkId);
        allow delete: if isOwner(userId) || isOwner(linkId);
      }

      // Invites stored under the user
      match /invites/{roomId} {
        allow read:   if isOwner(userId);
        allow create: if isSignedIn();
        allow update: if isSignedIn();
        allow delete: if isOwner(userId) || isRoomOwner(roomId) || isRoomLeader(roomId);
      }

      // Notifications: anyone signed in can push one to you, only you can read/manage
      match /notifications/{notifId} {
        allow read:   if isOwner(userId);
        allow create: if isSignedIn();
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      // Profile visitors: any signed-in user can write a visit; only owner can read the list
      match /profileVisitors/{visitorId} {
        allow read:   if isOwner(userId);
        allow create: if isSignedIn() && request.auth.uid == visitorId;
        allow update: if isSignedIn() && request.auth.uid == visitorId;
        allow delete: if isOwner(userId);
      }

      // Profile photos: owner manages; others can only read public photos
      match /profilePhotos/{photoId} {
        allow read:   if isSignedIn() && (
          isOwner(userId) || resource.data.visibility == 'public'
        );
        allow create: if isOwner(userId);
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }
    }

    // ─── Rooms ───────────────────────────────────────────────────────────────
    match /rooms/{roomId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      // Room owner or leader can update anything; others can only touch usersCount/speakersCount
      allow update: if isSignedIn() && (
        isRoomOwner(roomId) || isRoomLeader(roomId) ||
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['usersCount', 'speakersCount'])
      );
      allow delete: if isRoomOwner(roomId);

      // Members: room owner has full control.
      // Room leader can update any field EXCEPT isLeader.
      // Members may update their own doc but CANNOT elevate their own privileges.
      match /members/{memberId} {
        allow read:   if isSignedIn();
        allow create: if isOwner(memberId) || isRoomOwner(roomId) || isRoomLeader(roomId);
        allow update: if isRoomOwner(roomId)
                      || (isRoomLeader(roomId) && !touchesLeaderField())
                      || (isOwner(memberId) && !touchesSensitiveFields());
        allow delete: if isOwner(memberId) || isRoomOwner(roomId) || isRoomLeader(roomId);
      }

      // Kicked users: room owner or leader can manage this list
      match /kickedUsers/{userId} {
        allow read:   if isSignedIn();
        allow write:  if isRoomOwner(roomId) || isRoomLeader(roomId);
        allow delete: if isRoomOwner(roomId) || isRoomLeader(roomId);
      }

      // Room-level invites: owner or leader sends/revokes; invited user can read/delete their own
      match /invites/{userId} {
        allow read:   if isOwner(userId) || isRoomOwner(roomId) || isRoomLeader(roomId);
        allow create: if isRoomOwner(roomId) || isRoomLeader(roomId);
        allow update: if isRoomOwner(roomId) || isRoomLeader(roomId);
        allow delete: if isOwner(userId) || isRoomOwner(roomId) || isRoomLeader(roomId);
      }

      // Chat messages: any signed-in user can read and write (system + regular)
      match /messages/{messageId} {
        allow read:   if isSignedIn();
        allow create: if isSignedIn() && (
          request.resource.data.type == 'system' ||
          request.resource.data.userId == request.auth.uid
        );
        allow update: if isRoomOwner(roomId) || isRoomLeader(roomId);
        allow delete: if isRoomOwner(roomId) || isRoomLeader(roomId);
      }
    }

    // ─── Private Chats ───────────────────────────────────────────────────────
    match /privateChats/{chatId} {
      function isParticipant() {
        return isSignedIn() && resource.data.participants.hasAny([request.auth.uid]);
      }
      function willBeParticipant() {
        return isSignedIn() && request.resource.data.participants.hasAny([request.auth.uid]);
      }

      allow read:   if isParticipant();
      allow create: if willBeParticipant()
                    && request.resource.data.participants.size() == 2;
      allow update: if isParticipant();

      match /messages/{msgId} {
        allow read:   if isSignedIn() &&
          get(/databases/$(database)/documents/privateChats/$(chatId))
            .data.participants.hasAny([request.auth.uid]);
        allow create: if isSignedIn() &&
          request.resource.data.senderId == request.auth.uid &&
          get(/databases/$(database)/documents/privateChats/$(chatId))
            .data.participants.hasAny([request.auth.uid]);
        allow update: if isSignedIn() &&
          get(/databases/$(database)/documents/privateChats/$(chatId))
            .data.participants.hasAny([request.auth.uid]);
      }
    }
  }
}
