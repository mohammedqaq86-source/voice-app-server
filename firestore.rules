rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isRoomOwner(roomId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/rooms/$(roomId)).data.ownerId == request.auth.uid;
    }

    // ─── Users ───────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);

      // socialLinks: the owner of the doc OR the linked user (linkId) can write.
      // This allows friend-request writes where the sender writes into the
      // recipient's socialLinks doc whose document ID equals the sender's UID.
      match /socialLinks/{linkId} {
        allow read:   if isOwner(userId);
        allow write:  if isOwner(userId) || isOwner(linkId);
        allow delete: if isOwner(userId) || isOwner(linkId);
      }

      // Invites stored under the user: readable only by the user, writable by
      // anyone signed in (so room owners can send/revoke invites), deletable
      // by the user themselves or by the room owner when kicking.
      match /invites/{roomId} {
        allow read:   if isOwner(userId);
        allow create: if isSignedIn();
        allow update: if isSignedIn();
        allow delete: if isOwner(userId) || isRoomOwner(roomId);
      }
    }

    // ─── Rooms ───────────────────────────────────────────────────────────────
    match /rooms/{roomId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && isRoomOwner(roomId);
      allow delete: if isRoomOwner(roomId);

      // Members: the member themselves OR the room owner can write/delete.
      // This is the critical rule that allows give-mic, remove-mic, and kick.
      match /members/{memberId} {
        allow read:   if isSignedIn();
        allow write:  if isOwner(memberId) || isRoomOwner(roomId);
        allow delete: if isOwner(memberId) || isRoomOwner(roomId);
      }

      // Kicked users: only the room owner can manage this list.
      match /kickedUsers/{userId} {
        allow read:   if isSignedIn();
        allow write:  if isRoomOwner(roomId);
        allow delete: if isRoomOwner(roomId);
      }

      // Room-level invites: owner can send/revoke; the invited user can read/delete their own.
      match /invites/{userId} {
        allow read:   if isOwner(userId) || isRoomOwner(roomId);
        allow create: if isRoomOwner(roomId);
        allow update: if isRoomOwner(roomId);
        allow delete: if isOwner(userId) || isRoomOwner(roomId);
      }

      // Chat messages: any signed-in user in the room can read/write.
      match /messages/{messageId} {
        allow read:  if isSignedIn();
        allow write: if isSignedIn();
      }
    }
  }
}
